{
    "name": "redichat",
    "version": "1.1.0",
    "type": "module",
    "description": "A simple, real-time, multi-room terminal chat application using Node.js and Redis.",
    "main": "dist/ui.js",
    "bin": {
        "redichat": "bin/redichat.js"
    },
    "scripts": {
        "start": "node bin/redichat.js",
        "build": "esbuild src/ui.jsx --bundle --outfile=dist/ui.js --format=esm --platform=node --external:react --external:ink --external:ink-text-input --external:ioredis --external:uuid",
        "lint": "xo",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "bin",
        "dist",
        "LICENSE",
        "README.md"
    ],
    "keywords": [
        "redis",
        "chat",
        "terminal",
        "cli",
        "ink",
        "react",
        "nodejs",
        "pubsub"
    ],
    "author": "Geunseon Kim",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/geunseonkim/redichat.git"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "ink": "^4.4.1",
        "ink-text-input": "^4.0.1",
        "ioredis": "^5.3.2",
        "react": "^18.2.0",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "esbuild": "^0.19.8",
        "xo": "^0.56.0"
    },
    "xo": {
        "envs": [
            "node",
            "browser"
        ],
        "prettier": true,
        "space": true,
        "rules": {
            "react/react-in-jsx-scope": "off",
            "unicorn/filename-case": "off",
            "import/no-unassigned-import": "off"
        }
    }
}
